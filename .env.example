# ── IBM Bob API (primary) ─────────────────────────────────────────
BOB_API_URL=https://your-bob-endpoint.ibm.com/v1
BOB_API_KEY=your_bob_api_key_here
BOB_MODEL=bob-v1

# ── Fallback LLM (OpenAI-compatible) ─────────────────────────────
# Used automatically if BOB_API_URL is empty or Bob is unreachable.
# Works with: OpenAI, Anthropic (via proxy), Groq, Together, etc.
BOB_FALLBACK_URL=https://api.openai.com/v1
BOB_FALLBACK_API_KEY=sk-your-openai-key-here
BOB_FALLBACK_MODEL=gpt-4o
