# BlastRadius — Environment Variables
# Copy this file to .env and fill in your keys.

# ── IBM Bob API (primary LLM) ──────────────────────────────────────
# Get your API key from https://cloud.ibm.com/iam/apikeys
# Get your Project ID from https://dataplatform.cloud.ibm.com/
BOB_API_KEY=your-ibm-cloud-api-key
BOB_API_URL=https://jp-tok.ml.cloud.ibm.com/ml/v1/text/chat?version=2024-05-13
# BOB_MODEL: use model_id from watsonx.ai Foundation Models page
BOB_MODEL=meta-llama/llama-3-3-70b-instruct
BOB_PROJECT_ID=your-watsonx-project-id

# ── Fallback LLM (OpenAI-compatible, used if Bob is unavailable) ───
# Works with Groq, OpenAI, Together, etc.
BOB_FALLBACK_API_KEY=your-fallback-api-key
BOB_FALLBACK_URL=https://api.groq.com/openai/v1
BOB_FALLBACK_MODEL=llama-3.3-70b-versatile

# ── GitHub ─────────────────────────────────────────────────────────
# Optional — raises rate limit from 60 to 5,000 req/hr
GITHUB_TOKEN=your-github-token

# ── Deployment ─────────────────────────────────────────────────────
CORS_ORIGINS=https://your-frontend.vercel.app
STATIC_SAVE_SECRET=choose-any-random-string
