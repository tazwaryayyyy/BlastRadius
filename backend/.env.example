# BlastRadius — Environment Variables
# Copy this file to .env and fill in your keys.

# ── IBM Bob API (primary LLM) ──────────────────────────────────────
BOB_API_KEY=your-bob-api-key
BOB_API_URL=https://us-south.ml.cloud.ibm.com/ml/v1/text/generation
BOB_MODEL=ibm/granite-3-3-8b-instruct

# ── Fallback (OpenAI-compatible, used if Bob is unavailable) ───────
BOB_FALLBACK_API_KEY=your-fallback-key
BOB_FALLBACK_URL=https://api.openai.com/v1
BOB_FALLBACK_MODEL=gpt-4o

# ── GitHub ─────────────────────────────────────────────────────────
GITHUB_TOKEN=optional-raises-rate-limit

# ── Deployment ─────────────────────────────────────────────────────
CORS_ORIGINS=https://your-frontend.vercel.app
STATIC_SAVE_SECRET=choose-any-random-string

# ── Render dashboard (after pushing) ──────────────────────────────
# Add all vars above in Render → Environment.
# Delete GEMINI_API_KEY if it exists from a previous deployment.
